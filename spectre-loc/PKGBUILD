# Maintainer: Red Team <redteam@localhost>
pkgname=specter
pkgver=1.2.5
pkgrel=1
pkgdesc="Ghost Network Recon Engine (Standalone Nmap Scanner)"
arch=('any')
url="https://github.com/LoudLunatics/specter"
license=('MIT')
depends=('python' 'python-dotenv' 'python-rich' 'nmap')

# Menggunakan standar Arch Linux terbaru (PEP 517)
makedepends=('python-build' 'python-installer' 'python-wheel' 'python-setuptools')

# INI KUNCI UTAMANYA: Mengunduh langsung dari rilis GitHub v1.2.5
source=("$pkgname-$pkgver.tar.gz::https://github.com/LoudLunatics/specter/archive/refs/tags/v$pkgver.tar.gz")

# Kita lewati checksum dulu untuk memastikan instalasi jalan
sha256sums=('SKIP')

build() {
  # Masuk ke folder unduhan GitHub
  cd "$pkgname-$pkgver"
  python -m build --wheel --no-isolation
}

package() {
  # Instalasi roda (wheel) Python ke sistem Arch
  cd "$pkgname-$pkgver"
  python -m installer --destdir="$pkgdir" dist/*.whl
}
